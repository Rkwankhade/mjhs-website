// M.J. High School, Karanja Lad — Database Schema
// PostgreSQL via Neon

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== Enums =====================

enum NoticeCategory {
  GENERAL
  ACADEMIC
  EXAM
  SPORTS
  CULTURAL
  HOLIDAY
  ADMISSION
  RESULT
}

enum NoticeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventCategory {
  GENERAL
  ACADEMIC
  SPORTS
  CULTURAL
  HOLIDAY
  EXAMINATION
  ADMISSION
  OTHER
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum AchievementCategory {
  ACADEMIC
  SPORTS
  CULTURAL
  SCIENCE
  ARTS
  AWARD
  RECOGNITION
  OTHER
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

// ===================== Models =====================

model Admin {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  role      AdminRole   @default(STAFF)
  status    AdminStatus @default(PENDING)
  avatar    String?
  phone     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  auditLogs AuditLog[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}

enum AdminStatus {
  PENDING
  ACTIVE
  BLOCKED
}

model Faculty {
  id            String   @id @default(cuid())
  name          String
  designation   String
  department    String
  qualification String
  experience    Int
  email         String?
  phone         String?
  bio           String?  @db.Text
  image         String?
  imagePublicId String?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([department])
  @@index([isActive, order])
  @@map("faculty")
}

model Notice {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  category    NoticeCategory @default(GENERAL)
  status      NoticeStatus   @default(DRAFT)
  isPinned    Boolean        @default(false)
  pdfUrl      String?
  pdfPublicId String?
  publishedAt DateTime?
  expiresAt   DateTime?
  viewCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@map("notices")
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String?       @db.Text
  category      EventCategory @default(GENERAL)
  startDate     DateTime
  endDate       DateTime?
  venue         String?
  image         String?
  imagePublicId String?
  status        EventStatus   @default(UPCOMING)
  isFeatured    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, startDate])
  @@index([category])
  @@map("events")
}

model GalleryAlbum {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  category    String    @default("EVENTS")
  isPublished Boolean   @default(false)
  eventDate   DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images GalleryImage[]

  @@index([isPublished, order])
  @@map("gallery_albums")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  isCover   Boolean  @default(false)
  albumId   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@map("gallery_images")
}

model Achievement {
  id          String              @id @default(cuid())
  title       String
  description String?             @db.Text
  category    AchievementCategory @default(ACADEMIC)
  year        Int
  studentName String?
  teacherName String?
  level       AchievementLevel    @default(SCHOOL)
  isFeatured  Boolean             @default(false)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([year])
  @@index([category])
  @@map("achievements")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text")
  group     String   @default("general")
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  category  String        @default("GENERAL")
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@map("contact_messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model SiteSettings {
  id             String   @id @default(cuid())
  schoolName     String   @default("M.J. High School")
  tagline        String   @default("Nurturing Minds, Building Futures")
  address        String?  @db.Text
  phone          String?
  email          String?
  principalName  String?
  founded        Int      @default(1965)
  facebookUrl    String?
  youtubeUrl     String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

enum AchievementLevel {
  SCHOOL
  DISTRICT
  STATE
  NATIONAL
  INTERNATIONAL
}

